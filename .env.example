# Server Foundry — environment variables
#
# Copy this file to .env.local and fill in real values.
# Never commit .env.local. See docs/security.md for the full secrets table.
#
# Generate strong secrets with:
#   openssl rand -hex 32

# ── Runtime ────────────────────────────────────────────────────────
NODE_ENV=development

# ── Database (Postgres 16) ─────────────────────────────────────────
# For local dev, this matches docker-compose.yml.
DATABASE_URL=postgres://foundry:foundry@localhost:5432/foundry

# ── Better Auth ────────────────────────────────────────────────────
BETTER_AUTH_SECRET=replace-with-openssl-rand-hex-32
BETTER_AUTH_URL=http://localhost:3000

# ── OAuth providers (optional in Phase 0/1, required in Phase 2) ───
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Discord: https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ── Email (Resend) ─────────────────────────────────────────────────
# Required for Phase 1 waitlist confirmation emails.
RESEND_API_KEY=re_replace_me
RESEND_WEBHOOK_SECRET=
RESEND_FROM_EMAIL=hello@serverfoundry.gg

# ── Agent (Phase 4+) ───────────────────────────────────────────────
# HMAC secret for signing agent tokens; generate with `openssl rand -hex 32`.
AGENT_HMAC_SECRET=

# Encryption key for user-supplied S3 backup credentials at rest.
BACKUP_ENCRYPTION_KEY=

# ── Analytics (optional) ───────────────────────────────────────────
# Cloudflare Web Analytics — privacy-first, no cookies. Get your beacon token
# from the Cloudflare dashboard (Web Analytics → site → JS snippet, the token
# is the value after "data-cf-beacon"). Only loaded when NODE_ENV=production.
CLOUDFLARE_ANALYTICS_BEACON_TOKEN=

# ── Logging ────────────────────────────────────────────────────────
# Optional. Defaults to "debug" in dev, "info" in production.
# Levels: trace, debug, info, warn, error, fatal
LOG_LEVEL=
